# MongoDB connection string
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/deployplatform

# JWT secret (generate with: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-here

# Webhook secret for GitHub Actions callbacks
WEBHOOK_SECRET=your-webhook-secret-here

# GitHub Actions config (for the workflows repo)
GITHUB_WORKFLOWS_OWNER=your-github-username
GITHUB_WORKFLOWS_REPO=your-workflows-repo-name
GITHUB_ACTIONS_PAT=ghp_xxxxxxxxxxxx

# Cloudflare defaults (used when project doesn't supply their own)
CF_API_TOKEN=your-cloudflare-api-token
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_KV_NAMESPACE_ID=your-kv-namespace-id

# App URL (needed for webhook callbacks from GitHub Actions)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
